# ─────────────────────────────────────────────────────────────────────────────
# 1plabs Point — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────

NODE_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────

# Production database driver: postgres
# Dev fallback: set DB_DRIVER=sqlite and SQLITE_PATH=./local.db
DB_DRIVER=postgres

# PostgreSQL connection URL.
# If PostgreSQL runs in the same Docker network, use its service/container DNS name.
DATABASE_URL=postgresql://point:change-me@postgres:5432/point

# Set to "true" when the PostgreSQL server requires SSL.
DB_SSL=false

# SQLite dev fallback only. Do not use in production.
# DB_DRIVER=sqlite
# SQLITE_PATH=./local.db

# MySQL is still supported by the adapter but is not the production target.
# DATABASE_URL=mysql://root:secret@localhost:3306/1plabs_point

# ── Authentication ────────────────────────────────────────────────────────────

# Enable login protection for browser pages.
# Set to "true" in production; "false" can be used in local dev.
AUTH_ENABLED=true

# Password used to access the dashboard (/login page).
# Change this before deploying to production.
LOGIN_PASSWORD=change-me

# API keys for write operations (POST / PATCH / DELETE /api/items).
# Agents must send: Authorization: Bearer <agent key>
# Generate strong random values, e.g. openssl rand -hex 32
AGENT_API_KEY_XIAO_BLUE=change-me
AGENT_API_KEY_ASHE=change-me
AGENT_API_KEY_YAYA=change-me

# Legacy single-agent key, only if needed.
# AGENT_API_KEY=change-me

# ── Application ───────────────────────────────────────────────────────────────

# Base URL of the application, if needed for redirects or external links.
# NEXT_PUBLIC_APP_URL=https://point.1plabs.pro
