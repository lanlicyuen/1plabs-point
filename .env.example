# ─────────────────────────────────────────────────────────────────────────────
# 1plabs Point — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────

# Which database driver to use: postgres | mysql | sqlite
# Default: sqlite (great for local dev — no server needed)
DB_DRIVER=sqlite

# SQLite: path to the database file (only used when DB_DRIVER=sqlite)
SQLITE_PATH=./local.db

# PostgreSQL connection URL (only used when DB_DRIVER=postgres)
# Format: postgresql://user:password@host:5432/dbname
# DATABASE_URL=postgresql://postgres:secret@localhost:5432/1plabs_point

# MySQL connection URL (only used when DB_DRIVER=mysql)
# Format: mysql://user:password@host:3306/dbname
# DATABASE_URL=mysql://root:secret@localhost:3306/1plabs_point

# Set to "true" to require SSL for PostgreSQL connections
# DB_SSL=false

# ── Authentication ────────────────────────────────────────────────────────────

# Enable login protection for browser pages.
# Set to "true" in production; "false" in local dev (auth is skipped).
AUTH_ENABLED=false

# Password used to access the dashboard (/login page).
# Change this before deploying to production!
LOGIN_PASSWORD=12345aB!@#

# API key for write operations (POST / PATCH / DELETE /api/items).
# Agents must send: Authorization: Bearer <AGENT_API_KEY>
# Generate a strong random value: openssl rand -hex 32
AGENT_API_KEY=change-me-before-deploying

# ── Application ───────────────────────────────────────────────────────────────

# Base URL of the application (used for CORS and redirects in production)
# NEXT_PUBLIC_APP_URL=https://point.1plabs.pro
